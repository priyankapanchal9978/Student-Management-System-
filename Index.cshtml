@{
    ViewData["Title"] = "Student Management";
}
@model List<WebApplication2.Models.Student>
<h1>Student Management System</h1>

<a href="/Student/Create" class="btn btn-success">Add Student</a>

<br />
<br />

<table border="1" cellpadding="10">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Course</th>
        <th>City</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Course</td>
            <td>@item.City</td>
            <td>
                <a href="/Student/Edit/@item.Id" class="btn btn-warning">Edit</a>
                <a href="/Student/Delete/@item.Id" class="btn btn-danger">Delete</a>
            </td>
        </tr>
    }
</table>